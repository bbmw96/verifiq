<Window x:Class="VERIFIQ.Desktop.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="480" Height="300"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        ResizeMode="NoResize">
    <Border Background="#0B1F45" CornerRadius="12">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <Border Width="72" Height="72" Background="#0E7C86" CornerRadius="14"
                    HorizontalAlignment="Center" Margin="0,0,0,16">
                <TextBlock Text="VQ" Foreground="White" FontWeight="Bold"
                           FontSize="32" HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>
            <TextBlock Text="VERIFIQ" Foreground="White" FontFamily="Arial"
                       FontSize="40" FontWeight="Bold"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="IFC Compliance Checker" Foreground="#93C5FD"
                       FontFamily="Arial" FontSize="14"
                       HorizontalAlignment="Center" Margin="0,4,0,32"/>
            <ProgressBar Width="260" Height="4" IsIndeterminate="True"
                         Foreground="#0E7C86" Background="#1B3A6B"/>
            <TextBlock Text="Initialising..." Foreground="#64748B"
                       FontFamily="Arial" FontSize="12"
                       HorizontalAlignment="Center" Margin="0,12,0,0"/>
            <TextBlock Text="BBMW0 Technologies  |  Developed by Jia Wen Gan"
                       Foreground="#475569" FontFamily="Arial" FontSize="10"
                       HorizontalAlignment="Center" Margin="0,24,0,0"/>
        </StackPanel>
    </Border>
</Window>
