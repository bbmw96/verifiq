<Window x:Class="VERIFIQ.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="VERIFIQ: IFC Compliance Checker"
        Height="860" Width="1400"
        MinHeight="700" MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        Background="#F4F6FA">
    <Window.TaskbarItemInfo>
        <shell:TaskbarItemInfo Description="VERIFIQ: IFC Compliance Checker"/>
    </Window.TaskbarItemInfo>

    <Window.Resources>
        <!-- Country mode radio button style -->
        <Style x:Key="CountryModeButton" TargetType="RadioButton">
            <Setter Property="FontFamily"      Value="Arial"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Foreground"      Value="#555555"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="#CBD5E1"/>
            <Setter Property="Padding"         Value="12,6"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background"  Value="#0B1F45"/>
                                <Setter Property="Foreground"  Value="White"/>
                                <Setter Property="BorderBrush" Value="#0B1F45"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E8EDF4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sidebar nav item style -->
        <Style x:Key="NavItem" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#CBD5E1"/>
            <Setter Property="FontFamily"      Value="Arial"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding"         Value="20,12"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1B3A6B"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavItemActive" TargetType="Button" BasedOn="{StaticResource NavItem}">
            <Setter Property="Background" Value="#0E7C86"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <!-- Toolbar button styles -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background"      Value="#0B1F45"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontFamily"      Value="Segoe UI,Arial"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Padding"         Value="14,7"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1B3A6B"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TealButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#0E7C86"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#0A6672"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OutlineButton" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#0B1F45"/>
            <Setter Property="FontFamily"      Value="Segoe UI,Arial"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Padding"         Value="14,7"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="BorderBrush"     Value="#0B1F45"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E8EDF4"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>    <!-- Title bar -->
            <RowDefinition Height="26"/>    <!-- Menu bar -->
            <RowDefinition Height="42"/>    <!-- Country mode + toolbar -->
            <RowDefinition Height="*"/>     <!-- Main content -->
            <RowDefinition Height="22"/>    <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ═══ TITLE BAR ═══════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#0B1F45">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo + Name -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="26" Height="26" Background="#0E7C86" CornerRadius="6" Margin="0,0,10,0">
                        <TextBlock Text="VQ" Foreground="White" FontWeight="Bold" FontSize="11"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="VERIFIQ" Foreground="White" FontSize="16"
                               FontWeight="Bold" VerticalAlignment="Center"
                               FontFamily="Arial"/>
                    <TextBlock Text="  IFC Compliance Checker" Foreground="#93C5FD"
                               FontSize="11" VerticalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Licence info -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock x:Name="LicenceTierLabel" Text="" Foreground="#93C5FD"
                               FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock x:Name="LicencedToLabel" Text="" Foreground="#CBD5E1"
                               FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>

                <!-- Help / About -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="v2.0.0" Foreground="#64748B" FontSize="11"
                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <Button Content="?" Style="{StaticResource PrimaryButton}"
                            Width="28" Height="28" Padding="0"
                            Click="Help_Click" ToolTip="Help and Documentation"/>
                </StackPanel>
            </Grid>
        </Border>


        <!-- ═══ APPLICATION MENU BAR ════════════════════════════════════════ -->
        <Border Grid.Row="1" Background="#1B3A6B" BorderBrush="#0B1F45" BorderThickness="0,0,0,1">
            <Menu Background="Transparent" Foreground="White" FontFamily="Segoe UI,Arial" FontSize="12"
                  VerticalAlignment="Center" Margin="4,0">
                <Menu.Resources>
                    <Style TargetType="MenuItem">
                        <Setter Property="Background"  Value="Transparent"/>
                        <Setter Property="Foreground"  Value="#CBD5E1"/>
                        <Setter Property="FontFamily"  Value="Segoe UI,Arial"/>
                        <Setter Property="FontSize"    Value="12"/>
                        <Setter Property="Padding"     Value="10,5"/>
                        <Setter Property="BorderThickness" Value="0"/>
                    </Style>
                </Menu.Resources>

                <!-- File -->
                <MenuItem Header="_File">
                    <MenuItem Header="📂  Open IFC File..."       InputGestureText="Ctrl+O"   Click="MenuFile_Open"/>
                    <MenuItem Header="📁  Open Recent"            x:Name="MenuRecentFiles">
                        <MenuItem Header="(No recent files)" x:Name="MenuRecentPlaceholder" IsEnabled="False"/>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="📤  Export Report..."       InputGestureText="Ctrl+E"   Click="MenuFile_Export"/>
                    <Separator/>
                    <MenuItem Header="❌  Exit"                   InputGestureText="Alt+F4"   Click="MenuFile_Exit"/>
                </MenuItem>

                <!-- View -->
                <MenuItem Header="_View">
                    <MenuItem Header="📊  Dashboard"              Click="Nav_Dashboard_Click"/>
                    <MenuItem Header="📁  Loaded Files"           Click="Nav_Files_Click"/>
                    <MenuItem Header="✅  Validation"             Click="Nav_Validation_Click"/>
                    <MenuItem Header="🧊  3D Viewer"              Click="Nav_3DViewer_Click"/>
                    <MenuItem Header="📋  All Results"            Click="Nav_Results_Click"/>
                    <MenuItem Header="🚨  Critical Issues"        Click="Nav_Critical_Click"/>
                    <MenuItem Header="📐  Design Code"            Click="Nav_Design_Click"/>
                    <Separator/>
                    <MenuItem Header="📤  Export Reports"         Click="Nav_Export_Click"/>
                    <Separator/>
                    <MenuItem Header="⚙️  Settings"               Click="Nav_Settings_Click"/>
                </MenuItem>

                <!-- Validate -->
                <MenuItem Header="V_alidate">
                    <MenuItem Header="▶  Run Validation"          InputGestureText="F5"   Click="RunValidation_Click"/>
                    <MenuItem Header="⏹  Cancel Validation"       x:Name="MenuCancelValidation" IsEnabled="False" Click="MenuValidate_Cancel"/>
                    <Separator/>
                    <MenuItem Header="🇸🇬  Singapore (CORENET-X)"  Click="MenuValidate_ModeSG"/>
                    <MenuItem Header="🇲🇾  Malaysia (NBeS/UBBL)"   Click="MenuValidate_ModeMY"/>
                    <MenuItem Header="🌏  Combined (SG + MY)"      Click="MenuValidate_ModeCombined"/>
                    <Separator/>
                    <MenuItem Header="⚙️  Validation Settings..."  Click="Nav_Settings_Click"/>
                </MenuItem>

                <!-- Reports -->
                <MenuItem Header="_Reports">
                    <MenuItem Header="📝  Word (.docx)"           Click="MenuReport_Word"/>
                    <MenuItem Header="📄  PDF (Printable HTML)"   Click="MenuReport_Pdf"/>
                    <MenuItem Header="📊  Excel (.xlsx)"          Click="MenuReport_Excel"/>
                    <MenuItem Header="📋  CSV (.csv)"             Click="MenuReport_Csv"/>
                    <MenuItem Header="🌐  HTML (.html)"           Click="MenuReport_Html"/>
                    <MenuItem Header="{}  JSON (.json)"           Click="MenuReport_Json"/>
                    <MenuItem Header="🏗  BCF (.bcf)"             Click="MenuReport_Bcf"/>
                    <Separator/>
                    <MenuItem Header="📦  Export All Formats..."  Click="Export_Click"/>
                </MenuItem>

                <!-- Tools -->
                <MenuItem Header="_Tools">
                    <MenuItem Header="📏  Rules Database"         Click="Nav_Rules_Click"/>
                    <MenuItem Header="🔑  Licence Manager"        Click="Nav_Licence_Click"/>
                    <Separator/>
                    <MenuItem Header="🌐  Network Settings"       Click="MenuTools_Network"/>
                    <MenuItem Header="🔄  Check for Updates"      Click="MenuTools_CheckUpdates"/>
                </MenuItem>

                <!-- Help -->
                <MenuItem Header="_Help">
                    <MenuItem Header="📘  User Guide"             Click="MenuHelp_UserGuide"/>
                    <MenuItem Header="📖  Help &amp; Documentation" Click="Help_Click"/>
                    <MenuItem Header="❓  About VERIFIQ"          Click="Nav_About_Click"/>
                    <Separator/>
                    <MenuItem Header="🐛  Report an Issue"        Click="MenuHelp_ReportIssue"/>
                </MenuItem>
            </Menu>
        </Border>

        <!-- ═══ COUNTRY MODE BAR + TOOLBAR ═════════════════════════════════ -->
        <Border Grid.Row="2" Background="White"
                BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Country mode selector -->
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="Mode:" FontFamily="Arial" FontSize="12"
                               Foreground="#64748B" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="ModeSingapore"
                                     Content="🇸🇬  Singapore"
                                     Style="{StaticResource CountryModeButton}"
                                     GroupName="CountryMode"
                                     IsChecked="True"
                                     Checked="CountryMode_Changed"
                                     Margin="0,0,6,0"/>
                        <RadioButton x:Name="ModeMalaysia"
                                     Content="🇲🇾  Malaysia"
                                     Style="{StaticResource CountryModeButton}"
                                     GroupName="CountryMode"
                                     Checked="CountryMode_Changed"
                                     Margin="0,0,6,0"/>
                        <RadioButton x:Name="ModeCombined"
                                     Content="🌏  SG + MY"
                                     Style="{StaticResource CountryModeButton}"
                                     GroupName="CountryMode"
                                     Checked="CountryMode_Changed"/>
                    </StackPanel>
                </StackPanel>

                <!-- Divider -->
                <Border Grid.Column="1" Width="1" Background="#E2E8F0"
                        Margin="0,8" VerticalAlignment="Stretch"/>

                <!-- Active mode indicator -->
                <Border Grid.Column="2" x:Name="ActiveModeIndicator"
                        Background="#E8EDF4" CornerRadius="4"
                        Padding="10,4" VerticalAlignment="Center">
                    <TextBlock x:Name="ActiveModeText"
                               Text="Singapore: CORENET-X / IFC+SG"
                               FontFamily="Arial" FontSize="12"
                               Foreground="#0B1F45" FontWeight="SemiBold"/>
                </Border>

                <!-- Toolbar buttons -->
                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="📂  Open IFC File"
                            Style="{StaticResource PrimaryButton}"
                            Click="OpenFile_Click"
                            Margin="0,0,8,0"/>
                    <Button x:Name="ValidateButton"
                            Content="▶  Run Validation"
                            Style="{StaticResource TealButton}"
                            Click="RunValidation_Click"
                            IsEnabled="False"
                            Margin="0,0,8,0"/>
                    <Button x:Name="ExportButton"
                            Content="📊  Export Report"
                            Style="{StaticResource OutlineButton}"
                            Click="Export_Click"
                            IsEnabled="False"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ MAIN CONTENT ════════════════════════════════════════════════ -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>   <!-- Sidebar -->
                <ColumnDefinition Width="*"/>     <!-- Content -->
            </Grid.ColumnDefinitions>

            <!-- SIDEBAR ──────────────────────────────────────────────────── -->
            <Grid Grid.Column="0" Background="#0B1F45">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <ScrollViewer Grid.Row="0"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              CanContentScroll="False">
                <StackPanel>

                    <!-- ── SECTION: WORKFLOW ───────────────────────── -->
                    <Border Margin="14,14,14,2" Background="#112240"
                            CornerRadius="6" Padding="10,7">
                        <TextBlock Text="WORKFLOW" Foreground="#0E7C86"
                                   FontFamily="Arial" FontSize="9"
                                   FontWeight="Bold"/>
                    </Border>

                    <Button x:Name="NavDashboard" Content="📊  Dashboard"
                            Style="{StaticResource NavItemActive}"
                            Click="Nav_Dashboard_Click"
                            ToolTip="Compliance overview and score"/>
                    <Button x:Name="NavFiles" Content="📁  Loaded Files"
                            Style="{StaticResource NavItem}"
                            Click="Nav_Files_Click"
                            ToolTip="Open and manage IFC files"/>
                    <Button x:Name="NavValidation" Content="✅  Run Validation"
                            Style="{StaticResource NavItem}"
                            Click="Nav_Validation_Click"
                            ToolTip="Run 20-level compliance check"/>
                    <Button x:Name="Nav3DViewer" Content="🧊  3D Viewer"
                            Style="{StaticResource NavItem}"
                            Click="Nav_3DViewer_Click"
                            ToolTip="View model with compliance colours"/>

                    <!-- ── SECTION: RESULTS ────────────────────────── -->
                    <Border Margin="14,16,14,2" Background="#112240"
                            CornerRadius="6" Padding="10,7">
                        <TextBlock Text="RESULTS" Foreground="#0E7C86"
                                   FontFamily="Arial" FontSize="9"
                                   FontWeight="Bold"/>
                    </Border>

                    <Button x:Name="NavResults" Content="📋  All Results"
                            Style="{StaticResource NavItem}"
                            Click="Nav_Results_Click"
                            ToolTip="All compliance findings with 7 filters"/>
                    <Button x:Name="NavCritical" Content="🚨  Critical Issues"
                            Style="{StaticResource NavItem}"
                            Click="Nav_Critical_Click"
                            ToolTip="Issues that will cause submission rejection"/>
                    <Button x:Name="NavDesign" Content="📐  Design Code"
                            Style="{StaticResource NavItem}"
                            Click="Nav_Design_Click"
                            ToolTip="URA, BCA, SCDF, NEA, PUB dimension checks"/>
                    <Button x:Name="NavSearch" Content="🔍  Search Elements"
                            Style="{StaticResource NavItem}"
                            Click="Nav_Search_Click"
                            ToolTip="Search elements by name, class, GUID or code"/>

                    <!-- ── SECTION: FIX AND EXPORT ─────────────────── -->
                    <Border Margin="14,16,14,2" Background="#112240"
                            CornerRadius="6" Padding="10,7">
                        <TextBlock Text="FIX AND EXPORT" Foreground="#0E7C86"
                                   FontFamily="Arial" FontSize="9"
                                   FontWeight="Bold"/>
                    </Border>

                    <Button x:Name="NavPropEditor" Content="✏️  Property Editor"
                            Style="{StaticResource NavItem}"
                            Click="Nav_PropertyEditor_Click"
                            ToolTip="Fix property values without opening BIM software"/>
                    <Button x:Name="NavExport" Content="📤  Export Reports"
                            Style="{StaticResource NavItem}"
                            Click="Nav_Export_Click"
                            ToolTip="Export Word, Excel, PDF, BCF reports"/>
                    <Button x:Name="NavCobie" Content="📋  COBie Export"
                            Style="{StaticResource NavItem}"
                            Click="Nav_Cobie_Click"
                            ToolTip="Export asset handover data (COBie)"/>

                    <!-- ── SECTION: TOOLS ──────────────────────────── -->
                    <Border Margin="14,16,14,2" Background="#112240"
                            CornerRadius="6" Padding="10,7">
                        <TextBlock Text="TOOLS" Foreground="#0E7C86"
                                   FontFamily="Arial" FontSize="9"
                                   FontWeight="Bold"/>
                    </Border>

                    <Button x:Name="NavIds" Content="✓  IDS Checker"
                            Style="{StaticResource NavItem}"
                            Click="Nav_Ids_Click"
                            ToolTip="Validate against IDS specification files"/>
                    <Button x:Name="NavMerge" Content="⊕  IFC Merge"
                            Style="{StaticResource NavItem}"
                            Click="Nav_Merge_Click"
                            ToolTip="Federate multiple IFC discipline models"/>
                    <Button x:Name="NavRules" Content="📏  Rules Database"
                            Style="{StaticResource NavItem}"
                            Click="Nav_Rules_Click"
                            ToolTip="Browse all embedded COP3.1 rules and codes"/>
                    <Button x:Name="NavImport" Content="📥  Import Mapping"
                            Style="{StaticResource NavItem}"
                            Click="Nav_Import_Click"
                            ToolTip="Import BCA IFC+SG Industry Mapping Excel"/>

                    <!-- ── SECTION: HELP AND ACCOUNT ──────────────── -->
                    <Border Margin="14,16,14,2" Background="#112240"
                            CornerRadius="6" Padding="10,7">
                        <TextBlock Text="HELP AND ACCOUNT" Foreground="#0E7C86"
                                   FontFamily="Arial" FontSize="9"
                                   FontWeight="Bold"/>
                    </Border>

                    <Button x:Name="NavUserGuide" Content="📖  User Guide"
                            Style="{StaticResource NavItem}"
                            Click="Nav_UserGuide_Click"
                            ToolTip="Interactive step-by-step guide"/>
                    <Button x:Name="NavManual" Content="📚  User Manual"
                            Style="{StaticResource NavItem}"
                            Click="Nav_Manual_Click"
                            ToolTip="Full reference documentation"/>
                    <Button x:Name="NavLicence" Content="🔑  Licence"
                            Style="{StaticResource NavItem}"
                            Click="Nav_Licence_Click"
                            ToolTip="Activate or manage your licence"/>
                    <Button x:Name="NavSettings" Content="⚙️  Settings"
                            Style="{StaticResource NavItem}"
                            Click="Nav_Settings_Click"
                            ToolTip="Proxy, updates, country mode"/>
                    <Button x:Name="NavAbout" Content="ℹ️  About VERIFIQ"
                            Style="{StaticResource NavItem}"
                            Click="Nav_About_Click"
                            ToolTip="Version, credits, legal"/>

                </StackPanel>
                </ScrollViewer>

                    <!-- Compliance score indicator at bottom -->
                    <Border Grid.Row="1" Margin="12,12,12,12" Background="#1B3A6B"
                            CornerRadius="8" Padding="10">
                        <StackPanel>
                            <TextBlock x:Name="ScoreTitle" Text="Compliance Score"
                                       Foreground="#93C5FD" FontFamily="Arial"
                                       FontSize="11" HorizontalAlignment="Center"
                                       Margin="0,0,0,3"/>
                            <!-- FontSize 22 prevents overflow; ViewBox scales automatically -->
                            <Viewbox Stretch="Uniform" MaxHeight="32">
                                <TextBlock x:Name="ScoreValue" Text="-"
                                           Foreground="White" FontFamily="Arial"
                                           FontSize="26" FontWeight="Bold"
                                           HorizontalAlignment="Center"/>
                            </Viewbox>
                            <TextBlock x:Name="ScoreDetails" Text="Load a file to begin"
                                       Foreground="#64748B" FontFamily="Arial"
                                       FontSize="10" HorizontalAlignment="Center"
                                       TextWrapping="Wrap" Margin="0,4,0,0"
                                       LineHeight="14"/>
                        </StackPanel>
                    </Border>
            </Grid>

            <!-- WEBVIEW2 CONTENT PANEL ───────────────────────────────────── -->
            <Grid Grid.Column="1">
                <!-- WebView2 hosts the rich HTML/JS frontend UI -->
                <wv2:WebView2 x:Name="ContentWebView"
                              CoreWebView2InitializationCompleted="WebView_Initialized"/>

                <!-- Loading overlay -->
                <Border x:Name="LoadingOverlay" Background="#F4F6FA"
                        Visibility="Visible">
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <TextBlock x:Name="LoadingTitle"
                                   Text="VERIFIQ"
                                   FontFamily="Arial" FontSize="48"
                                   FontWeight="Bold" Foreground="#0B1F45"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="IFC Compliance Checker"
                                   FontFamily="Arial" FontSize="16"
                                   Foreground="#0E7C86"
                                   HorizontalAlignment="Center"
                                   Margin="0,4,0,32"/>
                        <ProgressBar x:Name="LoadingBar"
                                     Width="300" Height="4"
                                     IsIndeterminate="True"
                                     Foreground="#0E7C86"
                                     Background="#E2E8F0"/>
                        <TextBlock x:Name="LoadingStatus"
                                   Text="Initialising..."
                                   FontFamily="Arial" FontSize="12"
                                   Foreground="#64748B"
                                   HorizontalAlignment="Center"
                                   Margin="0,12,0,0"/>
                        <!-- Cancel button  -  only visible while validation is running -->
                        <Button x:Name="CancelValidationButton"
                                Content="✕  Cancel Validation"
                                Click="CancelValidation_Click"
                                Visibility="Collapsed"
                                Margin="0,20,0,0"
                                Padding="20,8"
                                Background="Transparent"
                                Foreground="#64748B"
                                BorderBrush="#CBD5E1"
                                BorderThickness="1"
                                FontFamily="Arial" FontSize="12"
                                HorizontalAlignment="Center"
                                Cursor="Hand"/>
                        <TextBlock Text="BBMW0 Technologies  |  Developed by Jia Wen Gan"
                                   FontFamily="Arial" FontSize="10"
                                   Foreground="#94A3B8"
                                   HorizontalAlignment="Center"
                                   Margin="0,32,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

