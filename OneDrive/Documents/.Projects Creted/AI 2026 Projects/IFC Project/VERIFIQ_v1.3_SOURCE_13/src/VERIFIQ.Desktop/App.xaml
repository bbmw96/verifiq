<Application x:Class="VERIFIQ.Desktop.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <!-- VERIFIQ Colour Palette -->
        <SolidColorBrush x:Key="NavyDark"  Color="#0B1F45"/>
        <SolidColorBrush x:Key="NavyMid"   Color="#1B3A6B"/>
        <SolidColorBrush x:Key="TealBrush" Color="#0E7C86"/>
        <SolidColorBrush x:Key="SilverBg"  Color="#E8EDF4"/>
        <SolidColorBrush x:Key="LightBg"   Color="#F4F6FA"/>
        <SolidColorBrush x:Key="TextDark"  Color="#1A1A1A"/>
        <SolidColorBrush x:Key="TextMid"   Color="#555555"/>
        <SolidColorBrush x:Key="GreenBrush" Color="#15803D"/>
        <SolidColorBrush x:Key="AmberBrush" Color="#B45309"/>
        <SolidColorBrush x:Key="RedBrush"  Color="#B91C1C"/>
        <SolidColorBrush x:Key="SgBlueBrush" Color="#1D4ED8"/>
        <SolidColorBrush x:Key="MyRedBrush" Color="#9B1C1C"/>

        <!-- Global font -->
        <FontFamily x:Key="AppFont">Arial</FontFamily>

        <!-- Button styles -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background"   Value="#0B1F45"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="FontFamily"   Value="Arial"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Padding"      Value="16,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1B3A6B"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#0E7C86"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TealButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#0E7C86"/>
        </Style>

        <Style x:Key="OutlineButton" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#0B1F45"/>
            <Setter Property="FontFamily"      Value="Arial"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Padding"         Value="16,8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="#0B1F45"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E8EDF4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Label styles -->
        <Style x:Key="HeadingLabel" TargetType="TextBlock">
            <Setter Property="FontFamily"  Value="Arial"/>
            <Setter Property="FontSize"    Value="20"/>
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="Foreground"  Value="#0B1F45"/>
        </Style>

        <Style x:Key="SubHeadingLabel" TargetType="TextBlock">
            <Setter Property="FontFamily"  Value="Arial"/>
            <Setter Property="FontSize"    Value="13"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Foreground"  Value="#0E7C86"/>
        </Style>

        <Style x:Key="BodyLabel" TargetType="TextBlock">
            <Setter Property="FontFamily"  Value="Arial"/>
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="Foreground"  Value="#1A1A1A"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </Application.Resources>
</Application>
